# ===================================
# Club 19 Sales OS - Environment Variables
# ===================================
#
# Copy this file to .env.local and fill in the values
# Get production keys from the respective service dashboards
#

# ===================================
# Authentication (Clerk)
# ===================================
# Get from: https://dashboard.clerk.com

# Public key (exposed to browser - safe for OAuth)
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# Server-only secret key (NEVER expose to client)
CLERK_SECRET_KEY=sk_test_...

# Clerk routing URLs
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard

# Clerk Frontend API endpoint (without https://)
# Example: your-app-123.clerk.accounts.dev
NEXT_PUBLIC_CLERK_FRONTEND_API=

# ===================================
# Application Settings
# ===================================

# Base URL for the application
# Development: http://localhost:3000
# Production: https://your-domain.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Vercel deployment URL (auto-set by Vercel, leave blank for local dev)
# VERCEL_URL=

# Node environment (auto-set, leave blank)
# NODE_ENV=development

# ===================================
# Database (PostgreSQL via Drizzle ORM)
# ===================================
# Get from: https://app.xata.io

# PostgreSQL connection URL (used by Drizzle ORM)
# Get from: Xata Dashboard > Database > Settings > PostgreSQL endpoint
# Format: postgresql://[workspace]:[api_key]@[region].sql.xata.sh/[database]:[branch]
XATA_POSTGRES_URL=postgresql://...

# ===================================
# Xero Integration
# ===================================
# Get from: https://developer.xero.com/app/manage

# OAuth Client ID (public, exposed to browser for OAuth flow)
NEXT_PUBLIC_XERO_CLIENT_ID=...

# OAuth Client Secret (server-only, NEVER expose)
XERO_CLIENT_SECRET=...

# Webhook signature secret
# Generate with: openssl rand -base64 32
XERO_WEBHOOK_SECRET=...

# STAGE 1: Single Integration User for Xero tokens
# All Xero tokens are stored on this user to prevent race conditions.
# ANY user can reconnect Xero - tokens are saved to this integration user.
# Get from: Clerk Dashboard > Users > find admin user > copy User ID
XERO_INTEGRATION_CLERK_USER_ID=user_...

# (DEPRECATED) System user ID - replaced by XERO_INTEGRATION_CLERK_USER_ID
# XERO_SYSTEM_USER_ID=user_...

# ===================================
# External Integrations (Optional)
# ===================================

# Make.com webhook URL for trade creation automation
# Leave blank to disable Make.com integration
MAKE_TRADE_WEBHOOK_URL=https://hook.eu2.make.com/...

# ===================================
# Google Sheets Integration (Phase 2 Workstream 2)
# ===================================
#
# Pushes wizard-created sales to per-shopper Google Sheets. Sheets are NOT
# the source of truth — the DB is. See lib/google-sheets.ts and CLAUDE.md
# (Google Sheets Integration section) for setup steps.
#
# Service account key, base64-encoded.
# Generate with: base64 -i path/to/service-account-key.json
GOOGLE_SERVICE_ACCOUNT_KEY_B64=<base64-encoded JSON key file>
#
# Per-shopper Google Sheet IDs. The sheet ID is the long string between /d/
# and /edit in the sheet URL. Each sheet must be shared with the service
# account email as Editor.
SHEET_ID_HOPE=<production: Hope's sheet id>
SHEET_ID_MC=<production: MC's sheet id>
#
# Catch-all sheet for sales whose shopper doesn't match Hope or MC. Sophie's,
# Alys's, and any unmapped shopper land here. Required in production.
SHEET_ID_MASTER=<production: master sheet id>
#
# Test sheet — used in all non-production environments for ALL shoppers, so
# dev work doesn't pollute the real per-shopper sheets.
SHEET_ID_TEST=<dev/preview: test sheet id>

# ===================================
# System Maintenance (Optional)
# ===================================

# Secret key for automated maintenance endpoints
# Generate with: openssl rand -base64 32
# Used by cron jobs to trigger daily sync operations
SYSTEM_MAINTENANCE_KEY=

# ===================================
# Security Notes
# ===================================
#
# PUBLIC variables (NEXT_PUBLIC_*):
# - Exposed to browser (client-side code)
# - Safe for OAuth client IDs (OAuth 2.0 spec allows this)
# - Never put secrets in NEXT_PUBLIC_* variables
#
# PRIVATE variables (without NEXT_PUBLIC_):
# - Server-only (Next.js API routes, Server Components)
# - Never exposed to client
# - Store all secrets here (API keys, client secrets)
#
# NEVER commit .env.local to version control!
# Only commit .env.example with placeholder values.
#

# ===================================
# Authorized Users
# ===================================
#
# Users must be invited via Clerk Dashboard and assigned a role
# in publicMetadata.staffRole:
#
# Roles:
# - superadmin: Full system access (Oliver)
# - founder: Business operations (company founders)
# - operations: Full operations + Deal Studio (Alys)
# - admin: Staff portal and admin tools (Sophie)
# - finance: Financial dashboards and commissions
# - shopper: Personal sales dashboard only (Hope, MC)
#
# See lib/permissions.ts for detailed role capabilities
#
